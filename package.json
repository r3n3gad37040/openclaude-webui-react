{
  "name": "openclaude-webui-react",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:server": "bun run src/server/index.ts",
    "dev:ui": "vite --port 5173",
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:ui\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "NODE_ENV=production bun run src/server/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@tanstack/react-query": "^5.67.3",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "hono": "^4.7.7",
    "lucide-react": "^0.482.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.3",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.2.0",
    "tsx": "^4.19.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.2.0"
  }
}
